#!/usr/bin/env bash
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: .sdd/bin/sdd-command <command> [arguments]" >&2
  echo "Example: .sdd/bin/sdd-command ideia \"add CSV export\"" >&2
  exit 1
fi

COMMAND="$1"
shift || true
ARGUMENTS="$*"
COMMAND_FILE=".sdd/commands/${COMMAND}.md"

if [[ ! -f "$COMMAND_FILE" ]]; then
  echo "Command not found: $COMMAND_FILE" >&2
  echo "Available commands:" >&2
  find .sdd/commands -maxdepth 1 -type f -name '*.md' -print | sed 's#^.*commands/##; s#\.md$##' | sort >&2
  exit 1
fi

python3 - "$COMMAND_FILE" "$ARGUMENTS" <<'PY'
import sys
import subprocess
from pathlib import Path

path = Path(sys.argv[1])
arguments = sys.argv[2]
text = path.read_text(encoding="utf-8")
text = text.replace("$ARGUMENTS", arguments)

def run(command):
    try:
        return subprocess.check_output(command, shell=True, text=True, stderr=subprocess.DEVNULL).strip()
    except Exception:
        return ""

print("Use the following SDD command prompt with your LLM/agent.")
print("It should operate inside the current repository and update files directly.")
print()
print("Runtime context:")
print(f"- cwd: {Path.cwd()}")
print(f"- date: {run('date +%Y-%m-%d')}")
changes = run("find docs/changes -maxdepth 1 -mindepth 1 -type d 2>/dev/null | sort")
print("- existing changes:")
print(changes if changes else "  (none)")
print()
print("=" * 80)
print(text)
PY
